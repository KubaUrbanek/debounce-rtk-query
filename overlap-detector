import { RefObject, useLayoutEffect } from "react";

type Options = {
  popupSelector?: string;
  elevatedZIndex?: number;
  normalZIndex?: number;
};

function overlaps(a: DOMRect, b: DOMRect) {
  return (
    a.left < b.right &&
    a.right > b.left &&
    a.top < b.bottom &&
    a.bottom > b.top
  );
}

export function useElevateOverlappingPopups(
  panelRef: RefObject<HTMLElement>,
  {
    popupSelector = "[data-popup]",
    normalZIndex = 1000,
    elevatedZIndex = 3000,
  }: Options = {}
) {
  useLayoutEffect(() => {
    const panel = panelRef.current;

    if (!panel) return;

    const check = () => {
      const panelRect = panel.getBoundingClientRect();

      const popups = document.querySelectorAll<HTMLElement>(
        popupSelector
      );

      for (const popup of popups) {
        const popupRect = popup.getBoundingClientRect();

        const isOverlapping = overlaps(
          panelRect,
          popupRect
        );

        popup.style.zIndex = isOverlapping
          ? String(elevatedZIndex)
          : String(normalZIndex);
      }
    };

    check();

    const observer = new MutationObserver(check);

    observer.observe(document.body, {
      childList: true,
      subtree: true,
    });

    window.addEventListener("resize", check);
    window.addEventListener("scroll", check, true);

    return () => {
      observer.disconnect();

      window.removeEventListener("resize", check);
      window.removeEventListener("scroll", check, true);
    };
  }, [
    panelRef,
    popupSelector,
    normalZIndex,
    elevatedZIndex,
  ]);
}
